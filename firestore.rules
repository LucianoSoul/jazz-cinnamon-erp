rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedUser() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function hasClaimRole(role) {
      return isSignedUser()
        && (
          request.auth.token.role == role
          || (role == 'admin' && request.auth.token.admin == true)
          || (role == 'producao' && request.auth.token.producao == true)
          || (request.auth.token.roles is list && request.auth.token.roles.hasAny([role]))
        );
    }

    function isAdmin() {
      return isSignedUser()
        && (
          hasClaimRole('admin')
          || request.auth.token.email in ['luciano.cinnamon@gmail.com']
        );
    }

    function isProducao() {
      return isSignedUser()
        && (
          hasClaimRole('producao')
          || request.auth.token.email in ['sergiodobass@gmail.com']
        );
    }

    function isSystemUser() {
      return isAdmin() || isProducao();
    }

    function isOwnPedidoWriter() {
      return isSystemUser()
        && (
          (resource.data.ownerUid is string && resource.data.ownerUid == request.auth.uid)
          || (resource.data.createdByUid is string && resource.data.createdByUid == request.auth.uid)
          || (resource.data.criadorUid is string && resource.data.criadorUid == request.auth.uid)
          || (resource.data.ownerEmail is string && resource.data.ownerEmail == request.auth.token.email)
          || (resource.data.criadorEmail is string && resource.data.criadorEmail == request.auth.token.email)
          || (resource.data.origemCriadorEmail is string && resource.data.origemCriadorEmail == request.auth.token.email)
        );
    }

    function isOwnPushSubscriptionWriter() {
      return isSystemUser()
        && request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email is string
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.role is string
        && request.resource.data.role in ['admin', 'producao']
        && request.resource.data.subscription is map;
    }

    function isPublicPedidoCreate(pedidoId) {
      return request.resource.data.keys().hasOnly([
          'cliente',
          'documento',
          'documentoLimpo',
          'whatsapp',
          'email',
          'dataStr',
          'horaInicio',
          'duracao',
          'cidade',
          'uf',
          'local',
          'tipo',
          'convidados',
          'status',
          'statusAgenda',
          'concorrentes',
          'valor',
          'valorPago',
          'statusPgto',
          'origem',
          'dataInsercaoLead',
          'data_insercao_lead',
          'criadoEm',
          'horaTermino',
          'atendimento',
          'grupoId',
          'eventoPrincipalId',
          'qtdApresentacoes',
          'temSubeventos',
          'subeventosIds',
          'id',
          'ehEventoPrincipal',
          'ehSubevento',
          'subeventoOrdem',
          'pedidoPrincipalFinanceiroId',
          'financeiroNoPrincipal',
          'apresentacoesGrupo'
        ])
        && request.resource.data.keys().hasAll([
          'cliente',
          'documentoLimpo',
          'whatsapp',
          'email',
          'dataStr',
          'horaInicio',
          'duracao',
          'cidade',
          'uf',
          'local',
          'tipo',
          'convidados',
          'status',
          'statusAgenda',
          'valor',
          'valorPago',
          'statusPgto',
          'criadoEm'
        ])
        && request.resource.data.cliente is string
        && request.resource.data.cliente.size() > 1
        && request.resource.data.cliente.size() <= 160
        && request.resource.data.documento is string
        && request.resource.data.documento.size() <= 24
        && request.resource.data.documentoLimpo is string
        && (
          request.resource.data.documentoLimpo.matches('^[0-9]{11}$')
          || request.resource.data.documentoLimpo.matches('^[0-9]{14}$')
        )
        && request.resource.data.whatsapp is string
        && request.resource.data.whatsapp.size() >= 8
        && request.resource.data.whatsapp.size() <= 30
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 160
        && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && request.resource.data.dataStr is string
        && request.resource.data.dataStr.matches('^[0-9]{2}[-/][0-9]{2}[-/][0-9]{4}$')
        && request.resource.data.horaInicio is string
        && request.resource.data.horaInicio.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')
        && request.resource.data.duracao is string
        && request.resource.data.duracao.matches('^[0-9]+:[0-5][0-9]$')
        && (!request.resource.data.keys().hasAny(['horaTermino'])
          || (request.resource.data.horaTermino is string
            && request.resource.data.horaTermino.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$')))
        && request.resource.data.cidade is string
        && request.resource.data.cidade.size() > 1
        && request.resource.data.cidade.size() <= 120
        && request.resource.data.uf is string
        && request.resource.data.uf.matches('^[A-Z]{2}$')
        && request.resource.data.local is string
        && request.resource.data.local.size() <= 180
        && request.resource.data.tipo is string
        && request.resource.data.tipo.size() <= 80
        && request.resource.data.convidados is string
        && request.resource.data.convidados.size() <= 6
        && request.resource.data.status == 'PRE_RESERVA'
        && request.resource.data.statusAgenda in ['LIVRE', 'OCUPADO', 'PENDENTE']
        && request.resource.data.concorrentes is list
        && request.resource.data.concorrentes.size() <= 30
        && request.resource.data.valor == 0
        && request.resource.data.valorPago == 0
        && request.resource.data.statusPgto == 'PENDENTE'
        && (!request.resource.data.keys().hasAny(['atendimento'])
          || request.resource.data.atendimento == 'Luciano')
        && (!request.resource.data.keys().hasAny(['origem'])
          || request.resource.data.origem in ['form_orcamento_publico', 'form_orcamento_publico_subevento'])
        && (!request.resource.data.keys().hasAny(['dataInsercaoLead'])
          || request.resource.data.dataInsercaoLead == request.time)
        && (!request.resource.data.keys().hasAny(['data_insercao_lead'])
          || request.resource.data.data_insercao_lead == request.time)
        && (!request.resource.data.keys().hasAny(['grupoId'])
          || (request.resource.data.grupoId is string
            && request.resource.data.grupoId.size() >= 8
            && request.resource.data.grupoId.size() <= 80))
        && (!request.resource.data.keys().hasAny(['eventoPrincipalId'])
          || (request.resource.data.eventoPrincipalId is string
            && request.resource.data.eventoPrincipalId.size() >= 8
            && request.resource.data.eventoPrincipalId.size() <= 80))
        && (!request.resource.data.keys().hasAny(['qtdApresentacoes'])
          || (request.resource.data.qtdApresentacoes is int
            && request.resource.data.qtdApresentacoes >= 1
            && request.resource.data.qtdApresentacoes <= 5))
        && (!request.resource.data.keys().hasAny(['temSubeventos'])
          || request.resource.data.temSubeventos is bool)
        && (!request.resource.data.keys().hasAny(['subeventosIds'])
          || (request.resource.data.subeventosIds is list
            && request.resource.data.subeventosIds.size() <= 4))
        && (!request.resource.data.keys().hasAny(['id'])
          || (request.resource.data.id is string
            && request.resource.data.id == pedidoId))
        && (!request.resource.data.keys().hasAny(['ehEventoPrincipal'])
          || request.resource.data.ehEventoPrincipal is bool)
        && (!request.resource.data.keys().hasAny(['ehSubevento'])
          || request.resource.data.ehSubevento is bool)
        && (!request.resource.data.keys().hasAny(['subeventoOrdem'])
          || (request.resource.data.subeventoOrdem is int
            && request.resource.data.subeventoOrdem >= 1
            && request.resource.data.subeventoOrdem <= 5))
        && (!request.resource.data.keys().hasAny(['pedidoPrincipalFinanceiroId'])
          || (request.resource.data.pedidoPrincipalFinanceiroId is string
            && request.resource.data.pedidoPrincipalFinanceiroId.size() >= 8
            && request.resource.data.pedidoPrincipalFinanceiroId.size() <= 80))
        && (!request.resource.data.keys().hasAny(['financeiroNoPrincipal'])
          || request.resource.data.financeiroNoPrincipal is bool)
        && (!request.resource.data.keys().hasAny(['apresentacoesGrupo'])
          || (request.resource.data.apresentacoesGrupo is list
            && request.resource.data.apresentacoesGrupo.size() >= 1
            && request.resource.data.apresentacoesGrupo.size() <= 5))
        && request.resource.data.criadoEm == request.time;
    }

    function isPublicLinkedPedido() {
      return !(resource.data.status in ['REPROVADO', 'LIXEIRA']);
    }

    function isPublicContractPatch() {
      return isPublicLinkedPedido()
        && resource.data.status in ['PRE_RESERVA', 'RESERVA']
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'dadosContrato',
          'valor',
          'temNf',
          'status'
        ])
        && request.resource.data.dadosContrato is map
        && request.resource.data.valor is number
        && request.resource.data.valor >= 0
        && request.resource.data.valor <= 1000000
        && request.resource.data.temNf is string
        && request.resource.data.temNf.size() <= 16
        && request.resource.data.status in ['PRE_RESERVA', 'RESERVA'];
    }

    function isPublicNfPatch() {
      return isPublicLinkedPedido()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'dadosNf',
          'nfStatus'
        ])
        && request.resource.data.dadosNf is map
        && request.resource.data.nfStatus == 'PENDENTE_CONTADOR';
    }

    function isPublicContractAttachmentPatch() {
      return isPublicLinkedPedido()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'anexos',
          'linkContrato'
        ])
        && request.resource.data.anexos is list
        && request.resource.data.anexos.size() <= 50
        && request.resource.data.linkContrato is string
        && request.resource.data.linkContrato.size() <= 500;
    }

    match /pedidos/{pedidoId} {
      allow get: if isSystemUser()
        || !exists(/databases/$(database)/documents/pedidos/$(pedidoId))
        || isPublicLinkedPedido();
      allow list: if isSystemUser();
      allow create: if isSystemUser() || isPublicPedidoCreate(pedidoId);
      allow update: if isAdmin()
        || isOwnPedidoWriter()
        || isPublicContractPatch()
        || isPublicNfPatch()
        || isPublicContractAttachmentPatch();
      allow delete: if isAdmin() || isOwnPedidoWriter();
    }

    match /pedidos/{pedidoId}/logs/{logId} {
      allow read: if isSystemUser();
      allow write: if false;
    }

    match /disponibilidade_publica/{pedidoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /producao_eventos/{pedidoId} {
      allow read: if isSystemUser();
      allow write: if false;
    }

    match /parceiros_som/{parceiroId} {
      allow read: if isSystemUser();
      allow write: if false;
    }

    match /security_events/{eventId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /links_publicos/{token} {
      allow read, write: if isAdmin();
    }

    match /push_subscriptions/{subscriptionId} {
      allow read: if isAdmin();
      allow write: if isAdmin() || isOwnPushSubscriptionWriter();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
